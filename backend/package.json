{
  "name": "order-backend",
  "version": "1.0.0",
  "description": "订单管理系统后端",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "verify": "node scripts/verifyData.js",
    "export": "node scripts/exportData.js all",
    "export:stores": "node scripts/exportData.js stores",
    "export:employees": "node scripts/exportData.js employees",
    "export:orders": "node scripts/exportData.js orders",
    "seed:verify": "npm run verify && npm run test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.0.1"
  }
}
